{
  "name": "vigie",
  "version": "0.3.1",
  "description": "Vigie — application de veille technologique",
  "homepage": "https://www.cyberlogic.fr",
  "main": "./out/main/index.js",
  "author": {
    "name": "Cyberlogic",
    "email": "contact@cyberlogic.fr",
    "url": "https://www.cyberlogic.fr"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "icons": "node scripts/gen-icons.mjs",
    "package": "npm run icons && electron-vite build && electron-builder --win --dir",
    "dist": "npm run icons && electron-vite build && electron-builder --win",
    "dist:msi": "npm run package && node scripts/build-msi.mjs",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "electron-updater": "^6.8.9",
    "linkedom": "^0.18.12",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "electron-wix-msi": "^5.1.3",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.vigie.app",
    "productName": "Vigie",
    "copyright": "Copyright © 2026 Cyberlogic",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "Cyberlogic91-dev",
        "repo": "vigie",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signtoolOptions": {
        "publisherName": "CYBERLOGIC",
        "certificateSha1": "D92CAF8ACED87FB45E138BBAD70C510F066E6655"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Vigie",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
